# Server Configuration
PORT=3001

# Langbly Translation API Key (REQUIRED for translation)
# Get your API key from: https://langbly.com/dashboard/keys
LANGBLY_API_KEY=your_langbly_api_key_here

# Sarvam AI API Key (REQUIRED for voice features - TTS only)
VITE_SARVAM_API_KEY=your_sarvam_api_key_here

# Porcupine Wake Word Detection (OPTIONAL for hands-free voice activation)
# Get your access key from: https://console.picovoice.ai/
VITE_PORCUPINE_ACCESS_KEY=your_porcupine_access_key_here

# Soil Classification ML Model API (ngrok endpoint)
# Replace with your actual ngrok URL
SOIL_CLASSIFY_API_URL=https://your-ngrok-url.ngrok-free.app/predict-soilhttps://your-soil-api.com/classify

# Agricultural Intelligence Engine API Keys
# OpenCage Geocoder API (REQUIRED for location data)
OPENCAGE_API_KEY=your_opencage_api_key_here

# Weather API Key (REQUIRED for weather data)
WEATHER_API_KEY=your_weather_api_key_here

# Sentinel Hub API (REQUIRED for satellite imagery)
SENTINEL_HUB_CLIENT_ID=your_sentinel_client_id_here
SENTINEL_HUB_CLIENT_SECRET=your_sentinel_client_secret_here

# Crop Health API Key (REQUIRED for crop health indicators)
CROP_HEALTH_API_KEY=your_crop_health_api_key_here

# Configuration
API_TIMEOUT_MS=10000
CACHE_WEATHER_HOURS=24
CACHE_SOIL_DAYS=7
CACHE_SATELLITE_DAYS=3
MAX_HISTORICAL_REPORTS=50
PARALLEL_API_REQUESTS=true

# Indian Government & FAO Data Sources
# These services provide India-specific agricultural data and global best practices
# No API keys required - services use public data and estimated values

# ISRO Bhuvan (Indian Space Research Organisation)
# - Soil moisture from EOS-04 satellite (500m resolution)
# - Agricultural stress monitoring
# - Place search and geospatial data
# Website: https://bhuvan.nrsc.gov.in

# Soil Health Card (Ministry of Agriculture, Govt of India)
# - 12 soil parameters (N, P, K, Zn, Fe, Cu, Mn, B, S, pH, EC, OC)
# - State-specific recommendations
# - Fertilizer doses in kg/ha
# Website: https://soilhealth.dac.gov.in

# FAO (Food and Agriculture Organization, UN)
# - Crop suitability recommendations
# - Fertilizer consumption trends
# - Climate-smart agriculture practices
# - Agricultural stress indices
# Website: https://www.fao.org
